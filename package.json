{
  "name": "les-petites-quetes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build && npm run check:bundle",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check:architecture": "node scripts/check-architecture.mjs",
    "check:cycles": "node scripts/check-cycles.mjs",
    "check:files": "node scripts/check-file-budgets.mjs",
    "check:assets": "node scripts/check-assets.mjs",
    "check:content": "node scripts/check-content.mjs",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check:browser": "node scripts/browser-smoke.mjs",
    "check": "npm run check:architecture && npm run check:cycles && npm run check:files && npm run check:assets && npm run check:content && npm run lint && npm run typecheck && npm run test:coverage && npm run build && npm run check:browser"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "25.6.2",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "^26.1.0",
    "puppeteer-core": "25.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
